MONGO_HOST=10.10.1.124
MONGO_PORT=27018
MONGO_USERNAME=pe_reader
MONGO_PASSWORD=your_password_here
MONGO_AUTH_SOURCE=admin

# Ollama LLM (local) — single model, nothing fancy
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_KEEP_ALIVE=60m
OLLAMA_TIMEOUT=180
# Context window. The app warms the model at this size via Ollama's native API.
# 16384 fits the schema + a few turns comfortably on a 12GB GPU (drop to 8192 if
# you hit VRAM limits). For a server-wide guarantee, also set OLLAMA_CONTEXT_LENGTH
# on the Ollama host.
OLLAMA_NUM_CTX=16384
