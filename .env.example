MONGO_HOST=10.10.1.124
MONGO_PORT=27018
MONGO_USERNAME=pe_reader
MONGO_PASSWORD=your_password_here
MONGO_AUTH_SOURCE=admin

# Ollama LLM (local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_PRIMARY_MODEL=deepseek-r1:14b
OLLAMA_FALLBACK_MODEL=qwen2.5:14b
OLLAMA_KEEP_ALIVE=60m
# Target context window. The app warms the model at this size and budgets every
# prompt to fit it. NOTE: Ollama's /v1 endpoint ignores per-request num_ctx, so for
# a guaranteed server-wide window also set OLLAMA_CONTEXT_LENGTH on the Ollama host.
OLLAMA_NUM_CTX=8192
